{
  "name": "tanvex",
  "description": "Full-stack TanStack Start + Convex + Better Auth starter. SSR auth, email OTP, user profiles, rate limiting.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Ray (https://github.com/ramonclaudio)",
  "repository": {
    "type": "git",
    "url": "https://github.com/ramonclaudio/tanvex"
  },
  "bugs": "https://github.com/ramonclaudio/tanvex/issues",
  "homepage": "https://github.com/ramonclaudio/tanvex#readme",
  "keywords": [
    "tanstack-start",
    "convex",
    "better-auth",
    "starter",
    "template",
    "ssr",
    "react",
    "typescript",
    "shadcn-ui",
    "tailwindcss",
    "bun",
    "zod",
    "resend",
    "authentication",
    "email-otp"
  ],
  "scripts": {
    "setup": "bun run scripts/setup.ts",
    "setup:local": "bun run scripts/setup.ts --local",
    "dev": "concurrently -k -n convex,vite -c blue,magenta \"bunx convex dev\" \"vite dev --port 3000\"",
    "dev:web": "vite dev --port 3000",
    "dev:convex": "bunx convex dev",
    "build": "vite build",
    "serve": "vite preview",
    "lint": "eslint",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix",
    "cleanup": "rm -rf node_modules bun.lock dist .output .nitro .tanstack .vite .cache convex/_generated src/routeTree.gen.ts tsconfig.tsbuildinfo && bun install && bunx convex dev --once"
  },
  "dependencies": {
    "@convex-dev/better-auth": "0.11.4",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/react-query": "0.1.0",
    "@convex-dev/resend": "^0.2.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-router-ssr-query": "^1.166.10",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.167.16",
    "@tanstack/router-plugin": "^1.167.12",
    "better-auth": "^1.6.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "convex-helpers": "^0.1.114",
    "lucide-react": "^1.7.0",
    "nitro": "^3.0.260311-beta",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  },
  "patchedDependencies": {
    "@convex-dev/better-auth@0.11.4": "patches/@convex-dev%2Fbetter-auth@0.11.4.patch"
  }
}
