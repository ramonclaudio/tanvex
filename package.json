{
  "name": "tanstack-convex-starter",
  "description": "Minimal starter. TanStack Start + Convex + Better Auth.",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "bun run scripts/setup.ts",
    "setup:local": "bun run scripts/setup.ts --local",
    "dev": "vite dev --port 3000",
