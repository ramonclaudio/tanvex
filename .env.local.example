# =============================================================================
# Local Development — .env.local
# =============================================================================
# These are client-side / dev-time variables that Vite reads from the
# repo root. `bun run setup` writes them automatically. If you're skipping
# setup and configuring by hand, copy this file to `.env.local` and fill
# in the values from your Convex dashboard at https://dashboard.convex.dev.
#
# Server-side secrets (SITE_URL, BETTER_AUTH_SECRET, RESEND_API_KEY, etc.)
# do NOT live here — they're stored on the Convex deployment itself.
# See `.env.convex.example` for those.

# -----------------------------------------------------------------------------
# Convex deployment identifier
# -----------------------------------------------------------------------------
# Get this from your Convex dashboard URL or by running `bunx convex dev --once`.
# Format: <env>:<project-name>  (e.g. "dev:upbeat-hound-866", "prod:my-app")
CONVEX_DEPLOYMENT=dev:your-project-name

# -----------------------------------------------------------------------------
# Convex API endpoint (the .convex.cloud URL — used by the client)
# -----------------------------------------------------------------------------
# Find this in the Convex dashboard under Settings > URL & Deploy Key,
# or `bunx convex dev --once` will write it for you.
VITE_CONVEX_URL=https://your-project-name.convex.cloud

# -----------------------------------------------------------------------------
# Convex site URL (the .convex.site URL — where HTTP routes are served)
# -----------------------------------------------------------------------------
# Powers Better Auth's /api/auth/* routes, the public /api/users endpoint,
# and the Resend webhook receiver. If you omit this, vite.config.ts will
# derive it from CONVEX_DEPLOYMENT (e.g. "dev:foo" → "https://foo.convex.site").
VITE_CONVEX_SITE_URL=https://your-project-name.convex.site
