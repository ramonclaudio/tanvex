# =============================================================================
# Local Development Environment Variables
# =============================================================================
# These are automatically created by `bunx convex dev --once`
# and `bun run setup`. You typically don't need to edit these manually.

# Convex deployment identifier (auto-generated by Convex CLI)
CONVEX_DEPLOYMENT=dev:your-project-name

# Convex cloud URL (auto-generated by Convex CLI)
VITE_CONVEX_URL=https://your-project-name.convex.cloud

# Convex site URL for HTTP endpoints (added by setup script)
VITE_CONVEX_SITE_URL=https://your-project-name.convex.site
