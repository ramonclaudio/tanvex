# Copy this file to `.env` and fill in the SEO values.
# Client-exposed vars must be prefixed VITE_ (import.meta.env).
#
# Convex vars below go in `.env.local` and are written automatically by
# `bun run setup`. Server-only secrets (SITE_URL, BETTER_AUTH_SECRET,
# RESEND_API_KEY, etc.) live on the Convex deployment itself, see
# `.env.convex.example`.

# -----------------------------------------------------------------------------
# SEO / branding (commit to `.env`, not `.env.local`)
# -----------------------------------------------------------------------------
# Where this app is deployed. Used for canonical URL, og:url, sitemap, JSON-LD.
# Keep in sync with SITE_URL in src/lib/site.ts.
VITE_SITE_URL=https://tanvex-demo.vercel.app

# -----------------------------------------------------------------------------
# Convex (written by `bun run setup` to `.env.local`)
# -----------------------------------------------------------------------------
# Deployment identifier. Format: <env>:<project-name> (e.g. "dev:upbeat-hound-866")
# CONVEX_DEPLOYMENT=dev:your-project-name

# Convex API endpoint (*.convex.cloud). Used by the client.
# VITE_CONVEX_URL=https://your-project-name.convex.cloud

# Convex site URL (*.convex.site). Hosts Better Auth /api/auth/* routes and
# the Resend webhook receiver. Derived from CONVEX_DEPLOYMENT if omitted.
# VITE_CONVEX_SITE_URL=https://your-project-name.convex.site
