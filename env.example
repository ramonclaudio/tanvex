# Copy this file to `.env.local` for development and `.env.prod` for production.
# Both target files are gitignored. Only this template is committed.
#
# Quickstart:
#   cp env.example .env.local && bun run setup
#   cp env.example .env.prod   # then fill in prod values manually
#
# `bun run setup` writes Convex deployment identifiers and URLs to `.env.local`
# automatically on first run. For prod, provision a separate Convex deployment
# with `bunx convex deploy` and copy its identifiers into `.env.prod`.
#
# Server-only secrets (`BETTER_AUTH_SECRET`, `RESEND_API_KEY`, etc.) live ON
# the Convex deployment itself, not in this file. See `.env.convex.example`
# for the Convex-side reference.
#
# Var naming:
#   VITE_*    client-exposed (`import.meta.env`), bundled into the JS
#   no prefix server/build-time only (loaded by vite.config.ts and SSR runtime)

# -----------------------------------------------------------------------------
# Convex deployment
# -----------------------------------------------------------------------------
# Format: <env>:<project-name> (e.g. "dev:upbeat-hound-866", "prod:fern-otter-42").
# Dev: written by `bun run setup`. Prod: provisioned by `bunx convex deploy`.
CONVEX_DEPLOYMENT=dev:your-project-name

# Convex API endpoint (*.convex.cloud). Used by the client.
VITE_CONVEX_URL=https://your-project-name.convex.cloud

# Convex site URL (*.convex.site). Hosts Better Auth `/api/auth/*` routes and
# the Resend webhook receiver. Derived from CONVEX_DEPLOYMENT if omitted.
VITE_CONVEX_SITE_URL=https://your-project-name.convex.site

# -----------------------------------------------------------------------------
# Site URL
# -----------------------------------------------------------------------------
# Where this app is deployed. Used for canonical URL, og:url, sitemap, JSON-LD,
# Better Auth's `baseURL`, and CORS allowed-origins on Convex HTTP endpoints.
#
# Dev:  http://localhost:3000
# Prod: https://your-app.vercel.app (or your custom domain)
#
# `SITE_URL` and `VITE_SITE_URL` should match. The unprefixed one is read by
# `vite.config.ts` at build time; the `VITE_` one is used by client-side SEO helpers.
SITE_URL=http://localhost:3000
VITE_SITE_URL=http://localhost:3000
