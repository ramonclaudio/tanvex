# =============================================================================
# Production Environment Variables
# =============================================================================
# Copy this to .env.production and fill in your values, or set these
# directly in your hosting provider (Vercel, Netlify, etc.)

# =============================================================================
# 1. Hosting Provider (Vercel/Netlify/etc.)
# =============================================================================

# Convex deployment identifier (get from dashboard.convex.dev)
CONVEX_DEPLOYMENT=prod:your-project-name

# Your production URL (must match your deployed domain)
SITE_URL=https://your-app.vercel.app

# =============================================================================
# 2. Convex Dashboard (dashboard.convex.dev -> Settings -> Environment Variables)
# =============================================================================
# Set these in your Convex project's production environment:
#
#   SITE_URL=https://your-app.vercel.app
#   BETTER_AUTH_SECRET=<generate with: openssl rand -base64 32>
#
# Or use the CLI:
#   bunx convex env set SITE_URL https://your-app.vercel.app --prod
#   bunx convex env set BETTER_AUTH_SECRET $(openssl rand -base64 32) --prod
#
# Note: CONVEX_SITE_URL is a built-in variable provided automatically by Convex.

